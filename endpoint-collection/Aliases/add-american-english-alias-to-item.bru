meta {
  name: Add American English Alias to Item
  type: http
  seq: 5
}

post {
  url: {{base-url}}/entities/items/{{sandbox-id}}/aliases/en-us
  body: json
  auth: inherit
}

body:json {
  {
    "aliases": [
      "Wikidata Sandbox Item"
    ],
    "tags": [],
    "bot": false,
    "comment": "Add American English alias"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
