meta {
  name: Add Statement to Item
  type: http
  seq: 1
}

post {
  url: {{base-url}}/entities/items/{{sandbox-id}}/statements
  body: json
  auth: inherit
}

body:json {
  {
    "statement": {
      "property": {
        "id": "P246742"
      },
      "value": {
        "type": "value",
        "content": "Musical scores are temporarily disabled."
      }
    },
    "tags": [],
    "bot": false,
    "comment": "Add statement"
  }
  
  
}

settings {
  encodeUrl: true
  timeout: 0
}
