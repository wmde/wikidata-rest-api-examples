meta {
  name: Replace English Label of Property
  type: http
  seq: 15
}

patch {
  url: {{base-url}}/entities/properties/{{property-id}}/labels
  body: json
  auth: inherit
}

body:json {
  {
    "patch": [
      {
        "op": "replace",
        "path": "/en",
        "value": "Sandbox string"
      }
    ],
    "tags": [],
    "bot": false,
    "comment": "replace English label"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
